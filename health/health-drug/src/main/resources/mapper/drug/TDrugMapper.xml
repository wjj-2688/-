<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.health.drug.mapper.TDrugMapper">
    
    <resultMap type="TDrug" id="TDrugResult">
        <result property="id"    column="id"    />
        <result property="code"    column="code"    />
        <result property="name"    column="name"    />
        <result property="specification"    column="specification"    />
        <result property="manufacturer"    column="manufacturer"    />
        <result property="unit"    column="unit"    />
        <result property="price"    column="price"    />
        <result property="stock"    column="stock"    />
        <result property="category"    column="category"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectTDrugVo">
        select id, code, name, specification, manufacturer, unit, price, stock, category, status, remark, create_by, create_time, update_by, update_time from t_drug
    </sql>

    <select id="selectTDrugList" parameterType="TDrug" resultMap="TDrugResult">
        <include refid="selectTDrugVo"/>
        <where>  
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="specification != null  and specification != ''"> and specification = #{specification}</if>
            <if test="manufacturer != null  and manufacturer != ''"> and manufacturer = #{manufacturer}</if>
            <if test="unit != null  and unit != ''"> and unit = #{unit}</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="stock != null "> and stock = #{stock}</if>
            <if test="category != null  and category != ''"> and category = #{category}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectTDrugById" parameterType="Long" resultMap="TDrugResult">
        <include refid="selectTDrugVo"/>
        where id = #{id}
    </select>

    <insert id="insertTDrug" parameterType="TDrug" useGeneratedKeys="true" keyProperty="id">
        insert into t_drug
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null">code,</if>
            <if test="name != null">name,</if>
            <if test="specification != null">specification,</if>
            <if test="manufacturer != null">manufacturer,</if>
            <if test="unit != null">unit,</if>
            <if test="price != null">price,</if>
            <if test="stock != null">stock,</if>
            <if test="category != null">category,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null">#{code},</if>
            <if test="name != null">#{name},</if>
            <if test="specification != null">#{specification},</if>
            <if test="manufacturer != null">#{manufacturer},</if>
            <if test="unit != null">#{unit},</if>
            <if test="price != null">#{price},</if>
            <if test="stock != null">#{stock},</if>
            <if test="category != null">#{category},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateTDrug" parameterType="TDrug">
        update t_drug
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null">code = #{code},</if>
            <if test="name != null">name = #{name},</if>
            <if test="specification != null">specification = #{specification},</if>
            <if test="manufacturer != null">manufacturer = #{manufacturer},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="category != null">category = #{category},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTDrugById" parameterType="Long">
        delete from t_drug where id = #{id}
    </delete>

    <delete id="deleteTDrugByIds" parameterType="String">
        delete from t_drug where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>